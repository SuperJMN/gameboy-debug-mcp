<Project Sdk="Microsoft.NET.Sdk">

  <ItemGroup>
    <ProjectReference Include="..\GameBoy.Debug.Core\GameBoy.Debug.Core.csproj" />
    <ProjectReference Include="..\GameBoy.Debug.Symbols\GameBoy.Debug.Symbols.csproj" />
    <ProjectReference Include="..\GameBoy.Debug.Emulator\GameBoy.Debug.Emulator.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Hosting" Version="10.0.9" />
    <PackageReference Include="ModelContextProtocol" Version="1.4.0" />
  </ItemGroup>

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <AssemblyName>GameBoy.Mcp</AssemblyName>
    <RootNamespace>GameBoy.Debug.Mcp</RootNamespace>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <!-- Distribution as a .NET tool (install with `dotnet tool install -g GameBoy.Mcp` or run with `dnx GameBoy.Mcp`) -->
  <PropertyGroup>
    <PackAsTool>true</PackAsTool>
    <ToolCommandName>gameboymcp</ToolCommandName>
    <PackageId>GameBoy.Mcp</PackageId>
    <Title>GameBoy.Mcp</Title>
    <Description>Cross-platform MCP server for inspecting and controlling Game Boy and Game Boy Color ROMs. Exposes CPU stepping, breakpoints, memory, PPU/VRAM inspection, savestates and inline screen captures over the Model Context Protocol. Pure managed core (no native dependencies).</Description>
    <Authors>SuperJMN</Authors>
    <Company>José Manuel Nieto (@SuperJMN)</Company>
    <Product>GameBoy.Mcp</Product>
    <PackageTags>mcp;model-context-protocol;gameboy;gameboy-color;debugger;emulator;ai</PackageTags>
    <PackageProjectUrl>https://github.com/SuperJMN/gameboy-debug-mcp</PackageProjectUrl>
    <RepositoryUrl>https://github.com/SuperJMN/gameboy-debug-mcp</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageRequireLicenseAcceptance>false</PackageRequireLicenseAcceptance>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PublishRepositoryUrl>true</PublishRepositoryUrl>
  </PropertyGroup>

  <ItemGroup>
    <None Include="..\..\README.md" Pack="true" PackagePath="" Visible="false" />
  </ItemGroup>

</Project>
